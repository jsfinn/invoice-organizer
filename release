#!/usr/bin/env bash

set -euo pipefail

PROJECT_SPEC="project.yml"
PROJECT_FILE="InvoiceOrganizer.xcodeproj/project.pbxproj"

usage() {
  echo "Usage: ./release [--next | version]" >&2
  echo "Examples:" >&2
  echo "  ./release          # interactive prompt" >&2
  echo "  ./release --next   # auto-bump revision" >&2
  echo "  ./release 0.1.4    # explicit version" >&2
}

ensure_xcode_project() {
  if ! command -v xcodegen >/dev/null 2>&1; then
    echo "xcodegen is required to regenerate InvoiceOrganizer.xcodeproj from ${PROJECT_SPEC}" >&2
    exit 1
  fi

  xcodegen generate --spec "${PROJECT_SPEC}" >/dev/null
}

ensure_main_not_behind_origin() {
  if ! git show-ref --verify --quiet refs/heads/main; then
    echo "Local main branch does not exist. Release aborted." >&2
    exit 1
  fi

  if ! git ls-remote --exit-code --heads origin main >/dev/null 2>&1; then
    echo "Remote origin/main does not exist. Release aborted." >&2
    exit 1
  fi

  git fetch origin main >/dev/null 2>&1

  local ahead behind
  read -r ahead behind <<<"$(git rev-list --left-right --count main...origin/main)"

  if [[ "${behind}" != "0" ]]; then
    echo "Local main is behind origin/main by ${behind} commit(s). Pull the latest main changes before releasing." >&2
    exit 1
  fi
}

read_current_version() {
  python3 - "$PROJECT_SPEC" <<'PY'
from pathlib import Path
import re
import sys

text = Path(sys.argv[1]).read_text()
match = re.search(r'(^\s*MARKETING_VERSION:\s*)(\d+\.\d+\.\d+)\s*$', text, re.MULTILINE)
if match is None:
    raise SystemExit("Could not read MARKETING_VERSION from project.yml")

print(match.group(2))
PY
}

read_current_build() {
  python3 - "$PROJECT_SPEC" <<'PY'
from pathlib import Path
import re
import sys

text = Path(sys.argv[1]).read_text()
match = re.search(r'(^\s*CURRENT_PROJECT_VERSION:\s*)(\d+)\s*$', text, re.MULTILINE)
if match is None:
    raise SystemExit("Could not read CURRENT_PROJECT_VERSION from project.yml")

print(match.group(2))
PY
}

bump_revision() {
  python3 - "$1" <<'PY'
import sys

parts = sys.argv[1].split(".")
if len(parts) != 3 or not all(part.isdigit() for part in parts):
    raise SystemExit("MARKETING_VERSION must use x.y.z format")

major, minor, revision = map(int, parts)
print(f"{major}.{minor}.{revision + 1}")
PY
}

prompt_for_version() {
  local current_version="$1"
  local suggested_version="$2"
  local response=""

  echo "Latest version: ${current_version}"

  if [[ ! -t 0 ]]; then
    echo "No version provided." >&2
    echo "Current version: ${current_version}" >&2
    echo "Suggested next version: ${suggested_version}" >&2
    echo "Re-run interactively or pass a version explicitly, for example: ./release ${suggested_version}" >&2
    return 1
  fi

  read -r -p "Release version [${suggested_version}]: " response
  VERSION="${response:-${suggested_version}}"
  return 0
}

next_build_number() {
  python3 - "$1" <<'PY'
import sys

value = sys.argv[1]
if not value.isdigit():
    raise SystemExit("CURRENT_PROJECT_VERSION must be numeric")

print(str(int(value) + 1))
PY
}

persist_versions() {
  python3 - "$1" "$2" "$PROJECT_SPEC" "$PROJECT_FILE" <<'PY'
from pathlib import Path
import re
import sys

marketing_version = sys.argv[1]
build_number = sys.argv[2]
paths = [Path(path) for path in sys.argv[3:]]
patterns = [
    (
        re.compile(r'(^\s*MARKETING_VERSION:\s*)\d+\.\d+\.\d+(\s*)$', re.MULTILINE),
        marketing_version,
    ),
    (
        re.compile(r'(^\s*MARKETING_VERSION = )\d+\.\d+\.\d+(;\s*)$', re.MULTILINE),
        marketing_version,
    ),
    (
        re.compile(r'(^\s*CURRENT_PROJECT_VERSION:\s*)\d+(\s*)$', re.MULTILINE),
        build_number,
    ),
    (
        re.compile(r'(^\s*CURRENT_PROJECT_VERSION = )\d+(;\s*)$', re.MULTILINE),
        build_number,
    ),
]

for path in paths:
    text = path.read_text()
    updated = text
    replacements = 0

    for pattern, replacement in patterns:
        updated, count = pattern.subn(rf'\g<1>{replacement}\g<2>', updated)
        replacements += count

    if replacements == 0:
        raise SystemExit(f"Could not update versions in {path}")

    path.write_text(updated)
PY
}

VERSION="${1:-}"

if [[ "${VERSION}" == "--next" ]]; then
  CURRENT_VERSION="$(read_current_version)"
  VERSION="$(bump_revision "${CURRENT_VERSION}")"
elif [[ -z "${VERSION}" ]]; then
  CURRENT_VERSION="$(read_current_version)"
  SUGGESTED_VERSION="$(bump_revision "${CURRENT_VERSION}")"
  prompt_for_version "${CURRENT_VERSION}" "${SUGGESTED_VERSION}" || exit 0
fi

if [[ ! "${VERSION}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "Version must use semantic version format: x.y.z" >&2
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Working tree must be clean before creating a release tag." >&2
  exit 1
fi

ensure_main_not_behind_origin

CURRENT_BUILD="$(read_current_build)"
NEXT_BUILD="$(next_build_number "${CURRENT_BUILD}")"
TAG="v${VERSION}"

if git rev-parse "${TAG}" >/dev/null 2>&1; then
  echo "Tag ${TAG} already exists locally." >&2
  exit 1
fi

persist_versions "${VERSION}" "${NEXT_BUILD}"
ensure_xcode_project
git add "${PROJECT_SPEC}" "${PROJECT_FILE}"
git commit -m "Release ${TAG}"
git tag -a "${TAG}" -m "Release ${TAG}"
git push origin HEAD
git push origin "${TAG}"

echo "Released ${TAG} with build ${NEXT_BUILD}"
